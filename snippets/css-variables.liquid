{% style %}
  {% # Loads all font variantions with display: swap %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    /* Fonts - Editorial Luxury */
    --font-heading: "Cormorant Garamond", "PP Editorial New", "Georgia", serif;
    --font-primary--family: {{ settings.type_primary_font.family }}, {{ settings.type_primary_font.fallback_families }}, "Geist", "Inter", sans-serif;
    --font-primary--style: {{ settings.type_primary_font.style }};
    --font-primary--weight: {{ settings.type_primary_font.weight }};
    
    /* Layout */
    --page-width: 1400px;
    --page-margin: 2rem;
    
    /* Brand Colors - Warm & Earthy */
    --color-background: #FAF5E8; /* Warm Cream */
    --color-foreground: #2C2A26; /* Espresso / Deep Brown */
    --color-brand-sage: #A4D4C5;
    --color-brand-pink: #D1A3A4;
    --color-brand-sand: #E8DFCB;
    
    /* Surface Colors (Double-Bezel) */
    --color-surface-shell: rgba(0, 0, 0, 0.03); /* Outer Shell */
    --color-surface-core: #F5EFE0; /* Inner Core */
    --color-surface-white: #FFFFFF;
    
    /* Structural / Borders */
    --style-border-radius-inputs: 12px;
    --radius-premium: 2rem;
    --radius-premium-inner: calc(2rem - 0.375rem);
    --border-hairline: rgba(0, 0, 0, 0.05);
  }
{% endstyle %}
