{% liquid
  assign statement = section.settings.statement | default: 'BLANKETTY.'
  assign menu = section.settings.menu
  assign menu_2 = section.settings.menu_2
%}

<footer class="min-footer full-width" id="Footer-{{ section.id }}">
  <div class="min-container">
    <!-- Top Statement -->
    <div class="min-footer-top">
      <h2 class="min-statement">{{ statement | escape }}</h2>
    </div>

    <!-- Middle Grid -->
    <div class="min-footer-grid">
      <!-- Newsletter -->
      <div class="min-footer-col min-newsletter">
        <h3 class="min-col-title">Stay Updated</h3>
        <p class="min-col-desc">
          Tham gia cùng chúng tôi để nhận những câu chuyện về sự thư thái và các bộ sưu tập mới nhất.
        </p>
        {% form 'customer', class: 'min-form' %}
          <div class="min-input-group">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="Địa chỉ email của bạn" class="min-input" required>
            <button type="submit" class="min-btn">→</button>
          </div>
        {% endform %}
      </div>

      <!-- Links 1 -->
      <div class="min-footer-col">
        {% if menu != blank %}
          <h3 class="min-col-title">{{ menu.title }}</h3>
          <ul class="min-link-list">
            {% for link in menu.links %}
              <li>
                <a href="{{ link.url }}" class="min-link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <h3 class="min-col-title">Sản phẩm</h3>
          <ul class="min-link-list">
            <li><a href="#" class="min-link">Chăn mùa đông</a></li>
            <li><a href="#" class="min-link">Vải lông thú</a></li>
            <li><a href="#" class="min-link">Khăn trải giường</a></li>
          </ul>
        {% endif %}
      </div>

      <!-- Links 2 -->
      <div class="min-footer-col">
        {% if menu_2 != blank %}
          <h3 class="min-col-title">{{ menu_2.title }}</h3>
          <ul class="min-link-list">
            {% for link in menu_2.links %}
              <li>
                <a href="{{ link.url }}" class="min-link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <h3 class="min-col-title">Thông tin</h3>
          <ul class="min-link-list">
            <li><a href="#" class="min-link">Về chúng tôi</a></li>
            <li><a href="#" class="min-link">Vận chuyển</a></li>
            <li><a href="#" class="min-link">Liên hệ</a></li>
          </ul>
        {% endif %}
      </div>
    </div>

    <!-- Bottom Meta -->
    <div class="min-footer-bottom">
      <div class="min-copyright">
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name | link_to: routes.root_url }}. All rights reserved. {{ powered_by_link }}
      </div>

      {% if section.settings.show_payment_icons %}
        <div class="min-payments">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'min-payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

<style>
  /* Base Reset for Minimalist UI Footer (Dark Mode) */
  .min-footer {
    background-color: var(--color-surface-dark, #0a0a0a);
    color: var(--color-on-dark, #ffffff);
    padding-top: 120px;
    padding-bottom: 40px;
    font-family: var(--font-family-body, sans-serif);
    width: 100%;
    float: left;
  }

  .min-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Top Statement */
  .min-footer-top {
    margin-bottom: 80px;
  }
  .min-statement {
    font-family: var(--font-family-display, serif);
    font-size: clamp(4rem, 10vw, 12rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: 0;
    color: var(--color-on-dark, #ffffff);
  }

  /* Middle Grid */
  .min-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 64px;
    padding-bottom: 80px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .min-col-title {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-dark, #ffffff);
    margin: 0 0 24px 0;
  }

  .min-col-desc {
    font-size: 1rem;
    color: var(--color-on-dark-soft, #a0a0a0);
    line-height: 1.6;
    margin: 0 0 24px 0;
    max-width: 400px;
  }

  /* Form & Input */
  .min-form {
    max-width: 400px;
  }
  .min-input-group {
    display: flex;
    gap: 8px;
  }
  .min-input {
    flex: 1;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px; /* Utilitarian radius */
    padding: 12px 16px;
    font-family: var(--font-family-body, sans-serif);
    font-size: 1rem;
    color: var(--color-on-dark, #ffffff);
    outline: none;
    transition: border-color 0.2s ease;
  }
  .min-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }
  .min-input:focus {
    border-color: rgba(255, 255, 255, 0.6);
  }
  .min-btn {
    background-color: var(--color-on-dark, #ffffff);
    color: var(--color-surface-dark, #0a0a0a);
    border: none;
    border-radius: 4px;
    padding: 0 24px;
    font-size: 1.25rem;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.32, 0.72, 0, 1), background-color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .min-btn:hover {
    background-color: #e0e0e0;
  }
  .min-btn:active {
    transform: scale(0.96); /* Subtle haptic motion */
  }

  /* Link Lists */
  .min-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .min-link {
    text-decoration: none;
    color: var(--color-on-dark-soft, #a0a0a0);
    font-size: 1rem;
    transition: color 0.2s ease;
  }
  .min-link:hover {
    color: var(--color-on-dark, #ffffff);
  }

  /* Bottom Meta */
  .min-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
  }
  .min-copyright {
    font-size: 0.875rem;
    color: var(--color-on-dark-soft, #a0a0a0);
  }
  .min-copyright a {
    color: inherit;
    text-decoration: none;
  }
  .min-copyright a:hover {
    text-decoration: underline;
  }
  .min-payments {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .min-payment-icon {
    height: 24px;
    width: auto;
    opacity: 0.6;
    filter: grayscale(100%) invert(100%);
    transition: filter 0.3s ease, opacity 0.3s ease;
  }
  .min-payment-icon:hover {
    opacity: 1;
    filter: grayscale(0%) invert(100%);
  }

  /* Mobile Layout */
  @media (max-width: 989px) {
    .min-footer {
      padding-top: 80px;
    }
    .min-statement {
      font-size: 4rem;
    }
    .min-footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-bottom: 48px;
    }
    .min-footer-top {
      margin-bottom: 48px;
    }
    .min-footer-bottom {
      flex-direction: column;
      gap: 24px;
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "Footer (Minimalist)",
  "settings": [
    {
      "type": "text",
      "id": "statement",
      "label": "Brand Statement",
      "default": "BLANKETTY."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer Menu 1"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Footer Menu 2"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
