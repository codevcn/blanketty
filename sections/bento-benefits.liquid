{% liquid
  assign bento_heading = section.settings.heading | default: 'Sự thoải mái trong từng sợi dệt'
%}

<section class="bento-benefits" id="Bento-{{ section.id }}">
  <div class="bento-inner">
    {% if bento_heading != blank %}
      <div class="bento-header">
        <h2 class="bento-heading">{{ bento_heading | escape }}</h2>
      </div>
    {% endif %}

    <div class="bento-grid">
      <!-- Card 1: Visual Texture (Large) -->
      <div class="bento-card bento-card--large bento-shell">
        <div class="bento-core">
          <img
            src="{{ 'texture_close_1781537790255.png' | asset_url }}"
            alt="Soft Texture"
            class="bento-img"
            loading="lazy"
            width="600"
            height="800"
          >
          <div class="bento-content-overlay">
            <h3>Chất liệu êm ái</h3>
            <p>An toàn cho da, giữ ấm nhưng vẫn thoáng khí.</p>
          </div>
        </div>
      </div>

      <!-- Card 2: Feature Stack -->
      <div class="bento-card bento-card--medium bento-shell bg-sand">
        <div class="bento-core bg-sand text-ink">
          <div class="bento-content-padded">
            <span class="bento-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </span>
            <h3>Thân thiện với môi trường</h3>
            <p>Sợi bông dệt tự nhiên, quy trình sản xuất không hóa chất độc hại.</p>
          </div>
        </div>
      </div>

      <!-- Card 3: Feature Stack -->
      <div class="bento-card bento-card--medium bento-shell bg-sage">
        <div class="bento-core bg-sage text-ink">
          <div class="bento-content-padded">
            <span class="bento-icon">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2M18 14h-8M15 18h-5"/>
              </svg>
            </span>
            <h3>Đa dạng kích thước</h3>
            <p>Phù hợp cho cả giường đơn, giường đôi, sofa hoặc mang đi du lịch.</p>
          </div>
        </div>
      </div>

      <!-- Card 4: Lifestyle (Wide) -->
      <div class="bento-card bento-card--wide bento-shell">
        <div class="bento-core">
          <img
            src="{{ 'cozy_lifestyle_1781537827471.png' | asset_url }}"
            alt="Lifestyle"
            class="bento-img"
            loading="lazy"
            width="1200"
            height="800"
          >
          <div class="bento-content-overlay bento-content-overlay--dark">
            <h3>Cảm giác như ở nhà</h3>
            <p>Một lớp chăn tạo nên không gian nghỉ ngơi thư giãn tuyệt đối.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-benefits {
    padding: calc(var(--page-margin) * 2) var(--page-margin);
    background-color: var(--color-background);
    margin-bottom: 4rem;
    border-radius: 28px;
  }
  .bento-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .bento-header {
    margin-bottom: 3rem;
  }
  .bento-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    color: var(--color-foreground);
    line-height: 1.2;
    font-weight: 400;
    width: max-content;
    margin: 0 auto;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: minmax(280px, auto);
    gap: 1.5rem;
  }

  /* Bento Shell (Double Bezel) */
  .bento-shell {
    background-color: var(--color-surface-shell);
    padding: 0.5rem;
    border-radius: var(--radius-premium);
    border: 1px solid var(--border-hairline);
  }
  .bento-core {
    background-color: var(--color-surface-core);
    border-radius: var(--radius-premium-inner);
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.15);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .bg-sand {
    background-color: var(--color-brand-sand);
  }
  .bg-sage {
    background-color: var(--color-brand-sage);
  }
  .text-ink {
    color: var(--color-foreground);
  }

  .bento-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .bento-shell:hover .bento-img {
    transform: scale(1.04);
  }

  .bento-content-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 2rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
    color: var(--color-surface-white);
  }
  .bento-content-overlay h3 {
    font-family: var(--font-primary--family);
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
    font-weight: 500;
  }
  .bento-content-overlay p {
    font-size: 1rem;
    margin: 0;
    opacity: 0.9;
  }

  .bento-content-padded {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  .bento-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .bento-content-padded h3 {
    font-size: 1.5rem;
    margin: 0 0 1rem 0;
    font-weight: 500;
  }
  .bento-content-padded p {
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    opacity: 0.8;
  }

  /* Span Rules */
  .bento-card--large {
    grid-column: span 1;
    grid-row: span 2;
  }
  .bento-card--medium {
    grid-column: span 1;
    grid-row: span 1;
  }
  .bento-card--wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  @media (max-width: 989px) {
    .bento-benefits {
      padding: calc(var(--page-margin) * 2) var(--page-margin);
    }
    .bento-grid {
      grid-template-columns: 1fr;
    }
    .bento-card--large,
    .bento-card--medium,
    .bento-card--wide {
      grid-column: span 1;
      grid-row: span 1;
      min-height: 350px;
    }
  }
</style>

{% schema %}
{
  "name": "Bento Benefits",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sự thoải mái trong từng sợi dệt"
    }
  ],
  "presets": [
    {
      "name": "Bento Benefits"
    }
  ]
}
{% endschema %}
