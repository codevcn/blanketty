{
  "name": "Danh sách sản phẩm",
  "settings": [
    {
      "type": "range",
      "id": "gallery_interval",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Thời gian chuyển tiếp ảnh",
      "default": 2
    }
  ]
}
