{% liquid
  assign heading = section.settings.heading | default: 'Mềm mại cho những ngày bạn chỉ muốn ở nhà.'
  assign text = section.settings.text | default: 'Giữ ấm vừa đủ, thoải mái suốt đêm. Khám phá bộ sưu tập chăn mền cao cấp giúp bạn tận hưởng trọn vẹn không gian nghỉ ngơi của mình.'
  assign button_label = section.settings.button_label | default: 'Khám phá ngay'
  assign button_link = section.settings.button_link | default: routes.collections_url
  assign fallback_image_url = 'hero_blanket_1781537779105.png' | asset_url
%}

<section class="hero-editorial-split" id="Hero-{{ section.id }}">
  <div class="hero-split__inner">
    <div class="hero-split__content-col">
      <div class="hero-split__content-wrapper">
        <h1 class="hero-split__heading">{{ heading | escape }}</h1>
        <p class="hero-split__text">{{ text | escape }}</p>

        {% if button_label != blank %}
          <a href="{{ button_link }}" class="hero-split__btn-outer group">
            <span class="hero-split__btn-text">{{ button_label | escape }}</span>
            <span class="hero-split__btn-icon">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </span>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="hero-split__image-col">
      <div class="hero-split__image-shell">
        <div class="hero-split__image-core">
          {% if section.settings.image != blank %}
            {{
              section.settings.image
              | image_url: width: 1600
              | image_tag: loading: 'eager', class: 'hero-split__image', widths: '540, 720, 1080, 1600'
            }}
          {% else %}
            <img
              src="{{ fallback_image_url }}"
              alt="Premium Blanket"
              class="hero-split__image"
              width="800"
              height="1000"
              loading="eager"
            >
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-editorial-split {
    min-height: 100dvh;
    padding: var(--page-margin);
    background-color: var(--color-background);
    display: flex;
    align-items: center;
  }
  .hero-split__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-split__content-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-split__heading {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }
  .hero-split__text {
    font-family: var(--font-primary--family);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.8;
    max-width: 32ch;
    margin-bottom: 3rem;
  }

  /* Button-in-Button Architecture */
  .hero-split__btn-outer {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-foreground);
    color: var(--color-background);
    padding: 0.5rem 0.5rem 0.5rem 2rem;
    border-radius: 9999px;
    text-decoration: none;
    width: fit-content;
    transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .hero-split__btn-outer:hover {
    transform: scale(0.98);
  }
  .hero-split__btn-text {
    font-weight: 500;
    font-size: 0.95rem;
    margin-right: 1.5rem;
  }
  .hero-split__btn-icon {
    width: 3rem;
    height: 3rem;
    background-color: rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1), background-color 0.3s ease;
  }
  .hero-split__btn-outer:hover .hero-split__btn-icon {
    transform: translateX(4px) translateY(-1px) scale(1.05);
    background-color: rgba(255, 255, 255, 0.25);
  }

  /* Double-Bezel Image Architecture */
  .hero-split__image-shell {
    background-color: var(--color-surface-shell);
    padding: 0.75rem;
    border-radius: var(--radius-premium);
    border: 1px solid var(--border-hairline);
  }
  .hero-split__image-core {
    background-color: var(--color-surface-core);
    border-radius: var(--radius-premium-inner);
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.15);
    aspect-ratio: 4/5;
  }
  .hero-split__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .hero-split__image-core:hover .hero-split__image {
    transform: scale(1.03);
  }

  @media (max-width: 989px) {
    .hero-editorial-split {
      padding-top: calc(var(--page-margin) * 3);
      min-height: auto;
    }
    .hero-split__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-split__heading {
      font-size: clamp(2.5rem, 8vw, 3.5rem);
    }
    .hero-split__text {
      max-width: 100%;
    }
    .hero-split__image-core {
      aspect-ratio: 1/1;
    }
  }
</style>

{% schema %}
{
  "name": "Editorial Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Mềm mại cho những ngày bạn chỉ muốn ở nhà."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Giữ ấm vừa đủ, thoải mái suốt đêm. Khám phá bộ sưu tập chăn mền cao cấp giúp bạn tận hưởng trọn vẹn không gian nghỉ ngơi của mình."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Khám phá ngay"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Editorial Hero"
    }
  ]
}
{% endschema %}
