{% liquid
  assign collection = collections['hoa-tiet-doc-dao-sang-tao']
  assign heading = section.settings.heading | default: 'Họa tiết sáng tạo'
%}

<section class="cp-awwwards-flush" id="Creative-{{ section.id }}">
  <div class="cp-header-wrapper">
    <div class="cp-header">
      <div class="cp-eyebrow">Thiết kế giới hạn</div>
      <h2 class="cp-heading">{{ heading | escape }}</h2>
    </div>
  </div>

  {% if collection != blank and collection.products_count > 0 %}
    <div class="cp-flush-grid">
      {% for product in collection.products limit: 9 %}
        <a href="{{ product.url }}" class="cp-card group">
          <div class="cp-image-wrap">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'cp-image' }}
            {% else %}
              {% assign placeholder_idx = forloop.index0 | modulo: 6 | plus: 1 %}
              {{ 'product-' | append: placeholder_idx | placeholder_svg_tag: 'cp-image placeholder-svg' }}
            {% endif %}

            <div class="cp-floating-box">
              <h3 class="cp-title">{{ product.title }}</h3>
              <p class="cp-price">{{ product.price | money }}</p>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  {% else %}
    <!-- dummy products -->
    <div class="cp-flush-grid">
      {% for i in (1..6) %}
        <a href="#" class="cp-card group">
          <div class="cp-image-wrap">
            {% assign placeholder_idx = i | modulo: 6 | plus: 1 %}
            {{ 'product-' | append: placeholder_idx | placeholder_svg_tag: 'cp-image placeholder-svg' }}

            <div class="cp-floating-box">
              <h3 class="cp-title">Sản phẩm mẫu {{ i }}</h3>
              <p class="cp-price">2,000,000₫</p>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  {% endif %}

  <div class="cp-view-all-wrapper">
    <a href="{{ collection.url | default: '#' }}" class="cp-view-all-btn">
      <span class="btn-text">Xem tất cả</span>
      <span class="btn-icon-wrapper">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 13L13 1M13 1H4M13 1V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  /* Base Reset for Section */
  .cp-awwwards-flush {
    background-color: var(--color-canvas, #ffffff);
    padding: 100px 0; /* Macro whitespace */
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .cp-awwwards-flush a {
    color: inherit;
    text-decoration: none;
  }

  .cp-header-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
    margin-bottom: 50px;
  }

  /* Header styles */
  .cp-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .cp-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 9999px;
    background-color: rgba(0, 0, 0, 0.04);
    font-family: var(--font-family-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-bottom: 24px;
    color: var(--color-muted);
  }
  .cp-heading {
    font-family: var(--font-family-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin: 0;
    color: var(--color-ink);
  }

  /* Flush Grid */
  .cp-flush-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    width: 100%;
  }

  .cp-card {
    position: relative;
    display: block;
    aspect-ratio: 16/11; /* landscape as requested */
    overflow: hidden;
    background-color: var(--color-surface-soft);
  }

  .cp-image-wrap {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .cp-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .cp-card:hover .cp-image {
    transform: scale(1.05);
  }

  /* Bottom Gradient Overlay */
  .cp-floating-box {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, transparent 100%);
    padding: 60px 24px 24px;
    transition: padding-bottom 0.6s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 10;
  }

  .cp-card:hover .cp-floating-box {
    padding-bottom: 32px;
  }

  .cp-title {
    font-family: var(--font-family-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: #ffffff;
    margin: 0 0 4px 0;
    line-height: 1.3;
  }
  
  .cp-price {
    font-family: var(--font-family-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* View All Button */
  .cp-view-all-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 60px;
  }

  .cp-view-all-btn {
    display: flex !important;
    align-items: center;
    gap: 16px;
    padding: 8px 8px 8px 32px;
    background-color: var(--color-ink);
    border-radius: var(--radius-pill, 9999px);
    color: var(--color-canvas) !important;
    font-size: var(--text-button-size, 14px);
    font-weight: var(--text-button-weight, 600);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.4s;
  }

  .cp-view-all-btn:hover {
    transform: scale(0.98);
  }

  .cp-view-all-btn .btn-icon-wrapper {
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-full, 9999px);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.4s;
  }

  .cp-view-all-btn:hover .btn-icon-wrapper {
    transform: translate(2px, -2px) scale(1.05);
    background-color: var(--color-canvas);
    color: var(--color-ink);
  }

  /* Mobile Responsive */
  @media (max-width: 989px) {
    .cp-awwwards-flush {
      padding: 60px 0;
    }
    .cp-header-wrapper {
      margin-bottom: 40px;
    }
    .cp-flush-grid {
      grid-template-columns: 1fr; /* 1 column on mobile */
    }
    .cp-floating-box {
      bottom: 16px;
      left: 16px;
      right: 16px;
      padding: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Creative Patterns Flush",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Họa tiết sáng tạo"
    }
  ],
  "presets": [
    {
      "name": "Creative Patterns Flush Grid"
    }
  ]
}
{% endschema %}
